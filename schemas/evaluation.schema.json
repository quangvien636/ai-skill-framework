{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-skill-framework.local/schemas/evaluation.schema.json",
  "title": "Evaluation Contract",
  "description": "Metrics, scoring, acceptance thresholds, and failure routing.",
  "type": "object",
  "required": ["metrics", "scoring", "acceptance", "on_failure"],
  "properties": {
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "weight", "rubric"],
        "properties": {
          "name": { "$ref": "metadata.schema.json#/$defs/kebabName" },
          "description": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
          "minimum_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "rubric": {
            "type": "object",
            "required": ["0", "50", "100"],
            "properties": {
              "0": { "type": "string", "minLength": 1 },
              "50": { "type": "string", "minLength": 1 },
              "100": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "scoring": {
      "type": "object",
      "required": ["scale", "aggregate"],
      "properties": {
        "scale": { "const": "0..100" },
        "aggregate": { "const": "weighted-mean" }
      },
      "additionalProperties": false
    },
    "acceptance": {
      "type": "object",
      "required": ["minimum_score"],
      "properties": {
        "minimum_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "hard_gates": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "metadata.schema.json#/$defs/kebabName" },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "on_failure": { "enum": ["fail", "reflect", "manual-review"] }
  },
  "additionalProperties": false,
  "examples": [{
    "metrics": [{
      "name": "accuracy",
      "description": "Claims are supported by supplied input.",
      "weight": 1,
      "rubric": { "0": "Contradicted.", "50": "Partially supported.", "100": "Fully supported." }
    }],
    "scoring": { "scale": "0..100", "aggregate": "weighted-mean" },
    "acceptance": { "minimum_score": 85, "hard_gates": ["output-schema-valid"] },
    "on_failure": "reflect"
  }]
}
