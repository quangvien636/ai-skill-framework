{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-skill-framework.local/schemas/reflection.schema.json",
  "title": "Reflection Contract",
  "description": "Bounded quality-improvement and retry policy.",
  "type": "object",
  "required": [
    "enabled",
    "max_attempts",
    "minimum_improvement",
    "on_exhausted",
    "reflectable_hard_gates"
  ],
  "properties": {
    "enabled": { "type": "boolean" },
    "max_attempts": { "type": "integer", "minimum": 0, "maximum": 3 },
    "minimum_improvement": { "type": "number", "minimum": 0, "maximum": 100 },
    "on_exhausted": { "enum": ["fail", "manual-review"] },
    "reflectable_hard_gates": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "metadata.schema.json#/$defs/kebabName" }
    }
  },
  "allOf": [{
    "if": { "properties": { "enabled": { "const": false } }, "required": ["enabled"] },
    "then": { "properties": { "max_attempts": { "const": 0 } } }
  }],
  "additionalProperties": false,
  "examples": [{
    "enabled": true,
    "max_attempts": 2,
    "minimum_improvement": 5,
    "on_exhausted": "manual-review",
    "reflectable_hard_gates": ["output-schema-valid"]
  }]
}
